{
  "email": {
    "server": {
      "host": "smtp.example.com",
      "port": 587,
      "password": "your-password-here",
      "email": "you@example.com"
    }
  },
  "defs": {
    "hackernews": {
      "url": "https://news.ycombinator.com",
      "pagination": {
        "type": "next_link",
        "selector": "a.morelink",
        "base_url": "https://news.ycombinator.com/",
        "max_pages": 2
      },
      "query": {
        "type": "list",
        "selector": "tr.athing.submission",
        "id": {
          "type": "attribute",
          "name": "id"
        },
        "variables": {
          "title": {
            "selector": ".titleline > a",
            "value": { "type": "text" }
          },
          "url": {
            "selector": ".titleline > a",
            "value": { "type": "attribute", "name": "href" }
          },
          "rank": {
            "selector": ".rank",
            "value": { "type": "text" },
            "default": ""
          },
          "score": {
            "sibling": true,
            "selector": ".score",
            "value": { "type": "text", "regex": "(\\d+)", "parse": "number" },
            "default": "0"
          },
          "age": {
            "sibling": true,
            "selector": ".age a",
            "value": { "type": "text" },
            "default": ""
          },
          "comments_url": {
            "sibling": true,
            "selector": ".age a",
            "value": {
              "type": "attribute",
              "name": "href",
              "prefix": "https://news.ycombinator.com/"
            },
            "default": ""
          }
        }
      }
    },
    "coinmarketcap": {
      "params": ["coin"],
      "url": "https://coinmarketcap.com/currencies/{{coin}}/",
      "query": {
        "type": "single",
        "selector": "[data-test='section-coin-stats']",
        "expect": ["[data-test='text-cdp-price-display']"],
        "id": {
          "source": "coin",
          "regex": "(.+)"
        },
        "variables": {
          "name": {
            "selector": "h1 span",
            "value": { "type": "text" }
          },
          "symbol": {
            "selector": "[data-role='coin-symbol']",
            "value": { "type": "text" }
          },
          "price": {
            "selector": "[data-test='text-cdp-price-display']",
            "value": { "type": "text", "parse": "money" }
          },
          "price_display": {
            "selector": "[data-test='text-cdp-price-display']",
            "value": { "type": "text" }
          }
        }
      }
    }
  },
  "rules": [
    {
      "ref": "hackernews",
      "name": "hackernews",
      "schedule": "0 */6 * * *",
      "subject": "Hacker News: {{count}} new stories",
      "template": "./templates/hackernews",
      "email": "you@example.com"
    },
    {
      "ref": "coinmarketcap",
      "name": "bitcoin-price",
      "schedule": "0 */4 * * *",
      "subject": "Bitcoin price alert: {{count}} threshold(s) crossed",
      "template": "./templates/coinmarketcap",
      "email": "you@example.com",
      "input": [
        {
          "params": { "coin": "bitcoin" },
          "validator": [
            { "test": "{{price}} >= 75000" },
            { "test": "{{price}} >= 80000" },
            { "test": "{{price}} >= 90000" },
            { "test": "{{price}} >= 100000" }
          ]
        },
        {
          "params": { "coin": "bitcoin" },
          "validator": [
            { "test": "{{price}} <= 60000" },
            { "test": "{{price}} <= 50000" },
            { "test": "{{price}} <= 40000" }
          ]
        }
      ]
    }
  ]
}
